# ============================================================
#  UEN300 — Sistema de Gestão de Contratos | Diefra
#  Arquivo: .env.example
#  Descrição: Variáveis de ambiente para conexão com o banco
#
#  INSTRUÇÕES:
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha com suas credenciais reais
#  3. NUNCA suba o arquivo .env para o Git!
# ============================================================

# --- Banco de Dados PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uen300
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_segura

# --- Aplicação ---
APP_PORT=3000
APP_ENV=development        # development | production

# --- Segurança ---
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria
JWT_EXPIRES_IN=8h

# --- Bcrypt ---
BCRYPT_ROUNDS=12
